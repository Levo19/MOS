{"url":"http://127.0.0.1:8124/index.html","waitMs":28000,"localStorage":{"mos_device_id":"7e57c1a0-de1c-4a7e-b0de-c47a10906474"},"evalAfter":"(async()=>{SeguridadSystem.abrirModalAlertas();await new Promise(r=>setTimeout(r,4500));const card=document.querySelector('#segAlertasBody .seg-card');const row=card.querySelector('.seg-card-row');const txt=row.children[1];const act=card.querySelector('.seg-card-actions');const btns=[...act.querySelectorAll('button')];const r=el=>{const b=el.getBoundingClientRect();return [Math.round(b.x),Math.round(b.y),Math.round(b.width),Math.round(b.height)];};return {card:r(card),row:r(row),txt:r(txt),act:r(act),btns:btns.map(r),cs:getComputedStyle(card).display,rowCs:getComputedStyle(row).display,bodyW:Math.round(document.getElementById('segAlertasBody').getBoundingClientRect().width)};})()"}
